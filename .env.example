# Server-side env vars (Vercel → Environment Variables)
# NO usan prefijo VITE_ — viven solo en las Vercel Functions, no en el bundle del cliente.

# Anthropic API key — usada por /api/mari (asistente Inge MARI) y /api/analyze (reportes)
# Sacar key en: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
